  },
  "print_ips": {
    "enabled": false,
    "display-ip-info": false,
    "max-concurrent": 4,
    "timeout": 5
  },
  "report_proxy": {
    "enabled": false,
    "url": "https://shareproxy.pro/proxy.php",
    "max-concurrent": 4,
    "timeout": 15
  },
  "timeout": {
    "http_timeout": 4,
    "socks4_timeout": 5,
    "socks5_timeout": 5
  }
}
